# ============================================
# LLM API 配置
# ============================================
# 默认使用演示模式（不需要API Key）
# 可选值：demo / openai / zhipu / claude / minimax
LLM_PROVIDER=demo

# ============================================
# 演示模式说明
# ============================================
# LLM_PROVIDER=demo 时，不需要任何API Key
# 会返回预设的示例响应，用于展示功能
#
# 正式使用时请切换到真实API：
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-api-key
# ============================================

# OpenAI 配置
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=gpt-4o

# 智谱GLM 配置
# ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_MODEL=glm-4

# Claude 配置
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# MiniMax 配置
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_GROUP_ID=your-group-id
# MINIMAX_MODEL=abab6.5s-chat